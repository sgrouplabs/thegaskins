---
/**
 * vault.astro — The Inspiration Hub (The Vault)
 * Masonry grid of curated inspiration cards with a horizontal bar of
 * elegant capsule-shaped tag filters at the top. Filtering is pure
 * client-side JS so no page reload is required.
 */
import DashboardLayout from '../layouts/DashboardLayout.astro';
import VaultCard from '../components/VaultCard.astro';
import ReelDesk from '../components/ReelDesk.tsx';
import { VAULT_CATEGORIES, VAULT_CARDS, SEED_REELS } from '../config/site';
---

<DashboardLayout
  active="vault"
  eyebrow="II · The Vault"
  title="The Inspiration Hub"
>
  <!-- Intro line -->
  <p class="font-serif  text-paper-300 text-lg max-w-2xl leading-relaxed mb-10 animate-fade-rise">
    A curated reference room. Study the frame before you film it.
  </p>

  <!-- The Reel Desk — saved reel links filmstrip (Preact island) -->
  <div class="mb-16 animate-fade-rise" style="animation-delay: 60ms">
    <ReelDesk client:load seedReels={SEED_REELS} />
  </div>

  <!-- Section divider before the inspiration grid -->
  <div class="flex items-center gap-6 mb-10">
    <div class="rule-hair flex-1"></div>
    <span class="eyebrow text-gold-muted">The Reference Room</span>
    <div class="rule-hair flex-1"></div>
  </div>

  <!-- Filter bar: capsule-shaped tag buttons -->
  <div
    class="flex flex-wrap gap-3 mb-10 animate-fade-rise"
    style="animation-delay: 80ms"
    role="tablist"
    aria-label="Filter inspiration by category"
  >
    {
      VAULT_CATEGORIES.map((cat, i) => (
        <button
          class:list={['capsule', i === 0 && 'is-active']}
          data-filter={cat}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {cat}
        </button>
      ))
    }
  </div>

  <!-- Masonry grid (CSS columns) -->
  <div
    id="vault-grid"
    class="columns-1 sm:columns-2 lg:columns-3 gap-6 animate-fade-rise"
    style="animation-delay: 140ms"
  >
    {
      VAULT_CARDS.map((card) => (
        <VaultCard card={card} />
      ))
    }
  </div>

  <!-- Empty state (shown by JS when a filter has no matches) -->
  <p
    id="vault-empty"
    class="hidden font-serif  text-paper-400 text-center py-20"
  >
    Nothing in this drawer — try another category.
  </p>
</DashboardLayout>

<script is:inline>
  (function () {
    function bind() {
      const tabs = document.querySelectorAll('[data-filter]');
      const cards = document.querySelectorAll('#vault-grid .vault-card');
      const grid = document.getElementById('vault-grid');
      const empty = document.getElementById('vault-empty');
      if (!tabs.length) return;

      tabs.forEach((tab) => {
        if (tab.dataset.bound === '1') return;
        tab.dataset.bound = '1';
        tab.addEventListener('click', () => {
          const filter = tab.getAttribute('data-filter');

          tabs.forEach((t) => {
            t.classList.remove('is-active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('is-active');
          tab.setAttribute('aria-selected', 'true');

          let visible = 0;
          cards.forEach((card) => {
            const cat = card.getAttribute('data-category');
            const show = filter === 'All' || cat === filter;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
          });

          if (grid) grid.style.display = visible === 0 ? 'none' : '';
          if (empty) empty.classList.toggle('hidden', visible !== 0);
        });
      });
    }

    bind();
    document.addEventListener('astro:page-load', bind);
  })();
</script>
