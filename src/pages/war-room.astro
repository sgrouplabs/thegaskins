---
/**
 * war-room.astro — The Memo Board (The War Room)
 * Renders the persistent layout shell and delegates the entire interactive
 * Kanban board to the WarRoomBoard Preact client island, which handles
 * drag-and-drop, reactive column counts, CRUD, and localStorage auto-save.
 *
 * Column headers display in the prominent serif font (Playfair Display)
 * via the island. Cards are textured cream digital stationery.
 */
import DashboardLayout from '../layouts/DashboardLayout.astro';
import WarRoomBoard from '../components/WarRoomBoard.tsx';
import { KANBAN_COLUMNS, MEMOS } from '../config/site';
---

<DashboardLayout
  active="war-room"
  eyebrow="III · The War Room"
  title="The Memo Board"
>
  <p class="font-serif text-paper-300 text-lg max-w-2xl leading-relaxed mb-12 animate-fade-rise">
    Half-thoughts, held gently. Move nothing until it is ready to be filmed.
  </p>

  <WarRoomBoard
    client:load
    initialMemos={MEMOS}
    columns={KANBAN_COLUMNS}
  />
</DashboardLayout>
