---
/**
 * war-room.astro — The Memo Board (The War Room)
 * A functional three-column Kanban layout. Cards are textured cream digital
 * stationery against the dark backdrop. Columns: Raw Ideas / In Refinement /
 * Ready to Film. Cards display title, quick tags, and summary.
 */
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { KANBAN_COLUMNS, MEMOS } from '../config/site';
---

<DashboardLayout
  active="war-room"
  eyebrow="III · The War Room"
  title="The Memo Board"
>
  <p class="font-serif italic text-paper-300 text-lg max-w-2xl leading-relaxed mb-12 animate-fade-rise">
    Half-thoughts, held gently. Move nothing until it is ready to be filmed.
  </p>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 animate-fade-rise" style="animation-delay: 80ms">
    {
      KANBAN_COLUMNS.map((col) => {
        const colMemos = MEMOS.filter((m) => m.status === col.id);
        return (
          <section class="flex flex-col min-h-[60vh]" data-col={col.id}>
            <header class="mb-5 pb-4 border-b border-veil-700 flex items-baseline gap-3">
              <span class="font-mono text-gold-muted text-sm w-6">{col.numeral}</span>
              <div class="flex-1">
                <h2 class="font-display text-lg text-paper-50">{col.label}</h2>
                <p class="eyebrow mt-1 text-paper-400">{colMemos.length} memos</p>
              </div>
            </header>

            <div class="space-y-5 flex-1">
              {colMemos.map((memo) => (
                <article
                  class="surface-stationery p-5 transition-transform duration-500 hover:-translate-y-0.5"
                  draggable="true"
                  data-memo={memo.id}
                >
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <h3 class="font-display text-lg leading-snug text-[#1f1d1a] flex-1">
                      {memo.title}
                    </h3>
                    <span class="font-mono text-[0.6rem] tracking-wide-luxe uppercase text-[#7a6f4f] mt-1">
                      {memo.id.toUpperCase()}
                    </span>
                  </div>

                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {memo.tags.map((tag) => (
                      <span class="text-[0.62rem] font-mono tracking-luxe uppercase text-[#6b5d3a] border border-[#d8c89c] px-2 py-0.5 rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>

                  <p class="font-serif text-[0.92rem] leading-relaxed text-[#3a342a] italic">
                    {memo.summary}
                  </p>

                  <div class="mt-4 pt-3 border-t border-[#e0d8c4] flex items-center justify-between">
                    <span class="text-[0.6rem] font-mono tracking-wide-luxe uppercase text-[#8a7d57]">
                      Memo
                    </span>
                    <span class="text-[0.6rem] font-mono tracking-wide-luxe uppercase text-[#8a7d57]">
                      ✎ Hold to drag
                    </span>
                  </div>
                </article>
              ))}

              {colMemos.length === 0 && (
                <div class="border border-dashed border-veil-600 rounded-[2px] p-6 text-center">
                  <p class="font-serif italic text-paper-400 text-sm">An empty drawer.</p>
                </div>
              )}
            </div>
          </section>
        );
      })
    }
  </div>

  <!-- War room footer note -->
  <div class="mt-14 rule-gold w-full max-w-[120px] mb-5"></div>
  <p class="font-serif italic text-paper-300 text-base max-w-xl">
    Drag a memo across columns when its shape has settled. The system does not
    enforce the move — you do.
  </p>
</DashboardLayout>

<script is:inline>
  // Lightweight HTML5 drag-and-drop between the three Kanban columns.
  // Visual only — no persistence layer in this stage.
  (function () {
    const memos = document.querySelectorAll('[data-memo]');
    const cols = document.querySelectorAll('[data-col]');

    memos.forEach((m) => {
      m.addEventListener('dragstart', () => {
        m.classList.add('opacity-50');
      });
      m.addEventListener('dragend', () => {
        m.classList.remove('opacity-50');
      });
    });

    cols.forEach((col) => {
      col.addEventListener('dragover', (e) => {
        e.preventDefault();
        col.classList.add('ring-1', 'ring-gold-500/30');
      });
      col.addEventListener('dragleave', () => {
        col.classList.remove('ring-1', 'ring-gold-500/30');
      });
      col.addEventListener('drop', (e) => {
        e.preventDefault();
        col.classList.remove('ring-1', 'ring-gold-500/30');
        const memo = document.querySelector('[data-memo].opacity-50');
        if (!memo) return;
        const target = col.querySelector('.space-y-5');
        if (target && !target.contains(memo)) target.appendChild(memo);
      });
    });
  })();
</script>
