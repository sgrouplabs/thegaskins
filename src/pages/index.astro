---
/**
 * index.astro — The Welcome Concierge (Home Dashboard)
 * Hero typographical header, dynamic greeting, "At a Glance" matrix,
 * and minimalist metric slats styled like a luxury magazine layout.
 */
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { BRAND, GLANCE_TASKS, METRICS } from '../config/site';

const hour = new Date().getHours();
const greet =
  hour < 12 ? 'Good morning' : hour < 18 ? 'Good afternoon' : 'Good evening';
const dateLabel = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<DashboardLayout active="home" eyebrow="I · Welcome" title={`${BRAND.name} — ${BRAND.tagline}`}>
  <!-- Hero greeting block -->
  <section class="animate-fade-rise" style="animation-delay: 60ms">
    <p class="font-mono text-[0.7rem] text-paper-400 tracking-wide-luxe uppercase">
      {dateLabel}
    </p>
    <p class="mt-4 font-display text-2xl md:text-3xl text-paper-50 leading-snug">
      {greet}. The desk is set.
    </p>
    <p class="mt-3 max-w-2xl font-serif  text-paper-300 text-lg leading-relaxed">
      A quiet, well-lit room for the work ahead. Three films on the calendar,
      a vault of references close at hand, and a war room waiting for your
      next idea.
    </p>
  </section>

  <div class="rule-hair my-12"></div>

  <!-- At a Glance matrix -->
  <section class="animate-fade-rise" style="animation-delay: 120ms">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-6">
      <div>
        <p class="eyebrow">At a Glance</p>
        <h2 class="font-display text-2xl text-paper-50 mt-2">
          The next three films.
        </h2>
      </div>
      <a
        href="/itinerary"
        class="gold-underline text-paper-300 hover:text-paper-50 text-sm tracking-luxe uppercase"
      >
        View full itinerary →
      </a>
    </div>

    <ol class="divide-y divide-veil-700 border-y border-veil-700">
      {
        GLANCE_TASKS.map((task, i) => (
          <li class="grid grid-cols-12 gap-4 py-6 items-baseline group">
            <span class="col-span-1 font-mono text-gold-muted text-sm">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="col-span-12 md:col-span-6">
              <h3 class="font-display text-xl text-paper-50 group-hover:text-gold-300 transition-colors duration-500">
                {task.title}
              </h3>
              <p class="mt-1 text-sm text-paper-300  font-serif">
                {task.vibe}
              </p>
            </div>
            <div class="col-span-6 md:col-span-3 text-paper-400 text-sm tracking-luxe uppercase">
              {task.vibe}
            </div>
            <div class="col-span-6 md:col-span-2 text-right md:text-left font-mono text-sm text-paper-200">
              {task.dateLabel}
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <div class="rule-hair my-12"></div>

  <!-- Metric slats — luxury magazine layout, not boxes -->
  <section class="animate-fade-rise" style="animation-delay: 180ms">
    <p class="eyebrow">Key Indicators</p>
    <h2 class="font-display text-2xl text-paper-50 mt-2 mb-8">
      The month, in figures.
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-veil-700 border border-veil-700">
      {
        METRICS.map((m) => (
          <div class="bg-onyx-900 px-6 py-8 flex flex-col justify-between min-h-[160px]">
            <p class="eyebrow text-paper-400">{m.label}</p>
            <div class="mt-6 flex items-baseline gap-1.5">
              <span class="font-display text-5xl text-paper-50 leading-none">
                {m.value}
              </span>
              <span class="font-mono text-sm text-gold-muted">{m.unit}</span>
            </div>
            <p class="mt-4 text-xs text-paper-400 leading-relaxed">{m.note}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Concierge footer line -->
  <section class="mt-16 animate-fade-rise" style="animation-delay: 240ms">
    <div class="rule-gold w-full max-w-[120px] mb-5"></div>
    <p class="font-serif  text-paper-300 text-lg max-w-2xl leading-relaxed">
      Should you need a quieter pace, the vault is one click away. The desk
      will hold your place.
    </p>
  </section>
</DashboardLayout>
