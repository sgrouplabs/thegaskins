---
/**
 * itinerary.astro — The Monthly Filming Schedule (The Itinerary)
 *
 * Layout: a clean grid calendar of the current month. Exactly four core
 * filming items, spread across two weeks starting Wed July 22, 2026.
 * No random dummy items — every populated date is a real shoot.
 *
 * Interactive engine: the side drawer is a Preact client island
 * (ItineraryDrawer.tsx). Clicking a date calls into the island via a
 * tiny bridge; the island owns the reactive status state and updates
 * both the drawer and the calendar cell indicator colors in place —
 * no full page reload.
 */
import DashboardLayout from '../layouts/DashboardLayout.astro';
import ItineraryDrawer from '../components/ItineraryDrawer.tsx';
import {
  ITINERARY_MONTH_LABEL,
  ITINERARY_MONTH_STARTS_ON,
  ITINERARY_MONTH_DAYS,
  SHOOTS,
} from '../config/site';

// Build a 6×7 calendar grid with leading blanks.
const cells: (number | null)[] = [];
for (let i = 0; i < ITINERARY_MONTH_STARTS_ON; i++) cells.push(null);
for (let d = 1; d <= ITINERARY_MONTH_DAYS; d++) cells.push(d);
while (cells.length % 7 !== 0) cells.push(null);

const WEEKDAYS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const shootByDay = new Map(SHOOTS.map((s) => [s.day, s]));

const statusDot: Record<string, string> = {
  pending: 'bg-status-pending',
  filmed: 'bg-status-filmed',
  edited: 'bg-status-edited',
};
---

<DashboardLayout
  active="itinerary"
  eyebrow="IV · The Itinerary"
  title="The Monthly Filming Schedule"
>
  <div class="flex items-end justify-between flex-wrap gap-4 mb-10 animate-fade-rise">
    <div>
      <p class="eyebrow">Current Month</p>
      <h2 class="font-display text-3xl text-paper-50 mt-2">{ITINERARY_MONTH_LABEL}</h2>
    </div>
    <div class="flex items-center gap-6 text-paper-400 text-xs tracking-luxe uppercase">
      <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-status-pending"></span>Pending</span>
      <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-status-filmed"></span>Filmed</span>
      <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-status-edited"></span>Edited</span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-10 animate-fade-rise" style="animation-delay: 80ms">
    <!-- Calendar grid -->
    <section>
      <div class="grid grid-cols-7 gap-px bg-veil-700 border border-veil-700">
        {
          WEEKDAYS.map((d) => (
            <div class="bg-onyx-900 px-2 py-3 text-center">
              <span class="eyebrow text-paper-400">{d}</span>
            </div>
          ))
        }
        {
          cells.map((day) => {
            const shoot = day ? shootByDay.get(day) : null;
            return (
              <div
                class:list={[
                  'bg-onyx-900 min-h-[96px] p-3 flex flex-col relative',
                  day === null && 'bg-onyx-950/60',
                ]}
              >
                {day && (
                  <span class="font-mono text-xs text-paper-400">
                    {String(day).padStart(2, '0')}
                  </span>
                )}
                {shoot && (
                  <button
                    class="itinerary-day group flex-1 mt-2 text-left cursor-pointer"
                    data-day={day}
                    data-shoot={shoot.id}
                    aria-label={`View shoot on ${shoot.weekdayLabel} July ${day}: ${shoot.title}`}
                  >
                    <div
                      class="flex items-center gap-1.5"
                      data-status-cell={shoot.id}
                      data-current-status={shoot.status}
                    >
                      <span
                        class:list={['w-1.5 h-1.5 rounded-full', statusDot[shoot.status]]}
                        data-cell-dot
                      ></span>
                      <span class="text-[0.7rem] font-sans text-paper-200 leading-tight line-clamp-2 group-hover:text-gold-300 transition-colors">
                        {shoot.title}
                      </span>
                    </div>
                  </button>
                )}
              </div>
            );
          })
        }
      </div>

      <p class="mt-5 text-[0.68rem] font-mono text-paper-400 tracking-wide-luxe uppercase">
        Four core shoots · two weeks · begins Wed Jul 22
      </p>
    </section>

    <!-- Preact island — the interactive detail drawer -->
    <ItineraryDrawer
      client:load
      shoots={SHOOTS}
      monthLabel={ITINERARY_MONTH_LABEL}
    />
  </div>
</DashboardLayout>

<!-- Bridge: static calendar buttons → Preact island (window.__itinerary__) -->
<script is:inline>
  (function () {
    function bind() {
      document.querySelectorAll('.itinerary-day').forEach((btn) => {
        if (btn.dataset.bound === '1') return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => {
          const day = Number(btn.getAttribute('data-day'));
          const ctrl = window.__itinerary__;
          if (ctrl && typeof ctrl.open === 'function') ctrl.open(day);
        });
      });
    }
    bind();
    document.addEventListener('astro:page-load', bind);
  })();
</script>

<style is:global>
  /* Drawer slide-in polish */
  .itinerary-drawer {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.5s ease, box-shadow 0.5s ease;
  }
  .itinerary-drawer.is-open {
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 30px 80px -30px rgba(212, 175, 55, 0.25);
  }
  .status-btn[aria-checked='true'] {
    box-shadow: 0 0 0 1px currentColor inset;
  }
</style>
